---
import { getCollection, type CollectionEntry } from 'astro:content'

import EmojiQuickCopy from '../../components/EmojiQuickCopy.astro'
import Layout from '../../layouts/Layout.astro'
import {
  emojiIntents,
  getEmojiIntentRoute,
  getEmojiIntentBySlug,
  getEmojiIntentLeadEmoji,
} from '../../data/emojiIntents'
import { buildIntentPageAlternates } from '../../lib/intentPageLocales'

type IntentEntry = CollectionEntry<'intent-pages'>

type PageProps = {
  entry: IntentEntry
  relevantEmoji: string[]
  leadEmoji: string
  relatedEntries: IntentEntry[]
}

export async function getStaticPaths() {
  const entries = await getCollection('intent-pages')

  return entries.map((entry) => {
    const intent =
      emojiIntents.find(
        (item) =>
          item.id === entry.data.intentId ||
          item.slug === entry.slug,
      ) ?? null

    if (
      !intent ||
      intent.id !== entry.data.intentId
    ) {
      throw new Error(
        `Intent page "${entry.slug}" references unknown intent id "${entry.data.intentId}".`,
      )
    }

    const relatedEntries = entry.data.relatedSlugs
      .map((relatedSlug) =>
        entries.find(
          (candidate) =>
            candidate.slug === relatedSlug,
        ),
      )
      .filter(
        (candidate): candidate is IntentEntry =>
          candidate != null,
      )

    return {
      params: {
        slug: entry.slug,
      },
      props: {
        entry,
        relevantEmoji: [...intent.relevant],
        leadEmoji: getEmojiIntentLeadEmoji(intent),
        relatedEntries,
      } satisfies PageProps,
    }
  })
}

const {
  entry,
  relevantEmoji,
  leadEmoji,
  relatedEntries,
} = Astro.props as PageProps
const { Content } = await entry.render()
const canonicalPath = getEmojiIntentRoute({
  slug: entry.slug,
})

function getLeadEmojiForSlug(slug: string) {
  const intent = getEmojiIntentBySlug(slug)
  return intent ? getEmojiIntentLeadEmoji(intent) : '🔎'
}
---

<Layout
	title={entry.data.title}
	description={entry.data.description}
	canonicalPath={canonicalPath}
	alternates={buildIntentPageAlternates(entry.slug)}
>
	<main class="mx-auto max-w-3xl px-4 pb-16 pt-20 md:pt-24">
		<nav class="mb-4 text-sm text-muted-foreground">
			<a href="/emoji-for/" class="no-underline hover:underline">Emoji hub</a>
			<span class="mx-2">/</span>
			<span>{entry.data.query}</span>
		</nav>

		<article class="space-y-7">
			<EmojiQuickCopy
				emojis={relevantEmoji}
				eyebrow={`Fast pick for ${entry.data.query}`}
				description="Tap the closest match to copy it instantly, then keep scrolling if you want nuance."
			/>

			<header class="space-y-3">
				<h1 class="flex items-start gap-3 text-3xl font-semibold leading-tight">
					<span aria-hidden="true" class="text-4xl leading-none">{leadEmoji}</span>
					<span>{entry.data.h1}</span>
				</h1>
				<p class="text-muted-foreground">{entry.data.description}</p>
			</header>

			<section class="space-y-4 text-base leading-7">
				<Content />
			</section>

			<section class="rounded-2xl border border-border bg-card p-4">
				<h2 class="text-base font-medium">Try your exact wording</h2>
				<p class="mt-2 text-sm text-muted-foreground">
					FetchMoji search is fastest when you type your natural phrase instead of a strict emoji
					name.
				</p>
				<a
					class="mt-4 inline-flex rounded-xl bg-primary px-4 py-2 text-sm font-medium text-primary-foreground no-underline"
					href="/"
				>
					{entry.data.ctaLabel}
				</a>
			</section>

			{
				relatedEntries.length > 0 ? (
					<section>
						<h2 class="text-base font-medium">Related emoji pages</h2>
						<div class="mt-3 grid gap-3 md:grid-cols-2">
							{
								relatedEntries.map((related) => (
									<a
										class="rounded-xl border border-border bg-card p-3 no-underline transition hover:border-primary/40"
										data-related-intent-link
										href={getEmojiIntentRoute({
											slug: related.slug,
										})}
									>
										<h3 class="flex items-center gap-2 text-sm font-medium text-foreground" data-related-intent-label>
											<span aria-hidden="true" data-related-intent-emoji>{getLeadEmojiForSlug(related.slug)}</span>
											<span>{related.data.query}</span>
										</h3>
										<p class="mt-1 text-sm text-muted-foreground">{related.data.description}</p>
									</a>
								))
							}
						</div>
					</section>
				) : null
			}
		</article>
	</main>
</Layout>
