{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FetchMoji Tauri",
  "version": "0.1.0",
  "identifier": "com.fetchmoji.prototype.tauri",
  "build": {
    "beforeDevCommand": "pnpm --dir ../desktop-ui dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm --dir ../desktop-ui build",
    "frontendDist": "../../desktop-ui/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FetchMoji",
        "width": 680,
        "height": 430,
        "minWidth": 680,
        "minHeight": 430,
        "maxWidth": 680,
        "maxHeight": 430,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
